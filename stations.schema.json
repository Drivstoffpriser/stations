{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Stations",
    "type": "array",
    "items": {
        "title": "Station",
        "type": "object",
        "required": [
            "id",
            "osm_id",
            "brand",
            "location",
            "address",
            "lat",
            "lon",
            "fuel_types"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "format": "uuid",
                "description": "Random UUID generated by the person who added the station",
                "examples": [
                    "a3bb189e-8bf9-3888-9912-ace4e6543002"
                ]
            },
            "osm_id": {
                "type": [
                    "string",
                    "null"
                ],
                "description": "OpenStreetMap ID. Null if not on OpenStreetMap yet",
                "examples": [
                    "7633012856",
                    null
                ]
            },
            "brand": {
                "type": "string",
                "enum": [
                    "AUTOMAT_1",
                    "BEST",
                    "BUNKER_OIL",
                    "CIRCLE_K",
                    "DRIV",
                    "ESSO",
                    "HALTBAKK_EXPRESS",
                    "OLJELEVERANDOREN",
                    "PREEM",
                    "ST1",
                    "TANKEN",
                    "TRONDER_OIL",
                    "UNO_X",
                    "YX",
                    "YX_TRUCK"
                ],
                "examples": [
                    "CIRCLE_K",
                    "YX",
                    "UNO_X"
                ]
            },
            "location": {
                "type": "string",
                "description": "Name of the location where the station is. Typically what a local would call the station.",
                "examples": [
                    "Kvinesdal",
                    "Sandvika",
                    "Trondheim sentrum"
                ]
            },
            "address": {
                "type": "string",
                "description": "Full address including street name, postal code and municipality",
                "examples": [
                    "Øyesletta 60, 4484 Øyestranda",
                    "Storgata 1, 0155 Oslo"
                ]
            },
            "lat": {
                "type": "number",
                "minimum": -90,
                "maximum": 90,
                "examples": [
                    58.2800346
                ]
            },
            "lon": {
                "type": "number",
                "minimum": -180,
                "maximum": 180,
                "examples": [
                    6.8952643
                ]
            },
            "fuel_types": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": [
                        "DIESEL",
                        "GASOLINE_95",
                        "GASOLINE_98",
                        "COLORED_DIESEL"
                    ]
                },
                "minItems": 1,
                "uniqueItems": true,
                "examples": [
                    [
                        "DIESEL",
                        "GASOLINE_95",
                        "GASOLINE_98"
                    ],
                    [
                        "DIESEL"
                    ]
                ]
            }
        }
    }
}